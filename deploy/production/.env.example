# Production deployment example for /opt/services/new-api/.env.
# Copy this file to .env on the server and replace placeholders.
# Never commit real database passwords, Redis passwords, SSH passwords, or SESSION_SECRET.

NEW_API_IMAGE=new-api:prod-20260605-b0ac0429-amd64
NEW_API_PORT=3000

# Must use the isolated new_api database in the existing PostgreSQL service.
# Do not point this at the sub2api database.
# On 43.160.242.244, sub2api-postgres is attached to host networking, so
# new-api reaches it via Docker host-gateway.
SQL_DSN=postgresql://new_api:<password>@host.docker.internal:5432/new_api?sslmode=disable
SQL_MAX_OPEN_CONNS=30
SQL_MAX_IDLE_CONNS=10
SQL_MAX_LIFETIME=60

# Must use Redis DB 1 in the existing Redis service.
# Do not use DB 0 because sub2api uses it.
# On 43.160.242.244, sub2api-redis is attached to host networking, so
# new-api reaches it via Docker host-gateway.
REDIS_CONN_STRING=redis://:<password>@host.docker.internal:6379/1

SESSION_SECRET=<generated-random-secret>
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=new-api-node-1
